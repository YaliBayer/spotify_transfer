# Spotify Developer App credentials — create one at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Must exactly match a Redirect URI registered on your Spotify app.
# Local dev:  http://127.0.0.1:3000/api/auth/callback
# Production: https://your-app.vercel.app/api/auth/callback
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback

# Random secret used to encrypt the session cookie. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=

# Optional — only needed for reading YouTube / YouTube Music playlists.
# Create a free API key in Google Cloud Console with the YouTube Data API v3 enabled.
YOUTUBE_API_KEY=
